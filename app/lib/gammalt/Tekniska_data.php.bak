<%

function show_info() {

$arg = func_get_arg (0);

if (!(isset($arg)))
echo "-";
else
echo $arg;

}

function show_info2() {

$arg = func_get_arg (0);

if (!(isset($arg)))
	echo "-";
	else {

	$arg = number_format ($arg, 0, ",", " ");
	echo $arg;
	}

}


function show_pic() {

$arg = func_get_arg (0);

if (!(isset($arg))):
echo "-";

else:
$newargument = split ("\|", $arg);
$n = count($newargument);
echo "\n";

for ($i=0; $i<=$n; $i+=2) {

	$link = $newargument[$i];
	$name = $newargument[$i+1];
echo <<<eof
	<a href="$link">$name</a><br>\n
eof;

	}

endif;

}


