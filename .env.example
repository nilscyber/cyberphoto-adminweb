# MySQL/MariaDB - standard (read)
DB_HOST=db
DB_USER=appuser
DB_PASS=apppass
DB_NAME=cyberphoto

# MySQL/MariaDB - master (write)
DB_HOST_MASTER=db
DB_USER_MASTER=appuser
DB_PASS_MASTER=apppass

# ADempiere PostgreSQL
AD_HOST=db
AD_HOST_MASTER=db
AD_PORT=5432
AD_DBNAME=adempiere
AD_USER=adempiere
AD_PASS=password

# OTRS (separate server)
OTRS_HOST=otrs-server
OTRS_USER=otrs
OTRS_PASS=password
OTRS_DBNAME=otrs

# Microsoft Entra (OAuth)
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret
